NODE_ENV=development
PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/turfx?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-random-secret-at-least-32-characters-long
JWT_EXPIRES_IN=7d
JWT_COOKIE_EXPIRES_DAYS=7
CLIENT_URL=http://localhost:5173
API_BASE_URL=http://localhost:5000
API_RATE_LIMIT=600

# Optional SMTP settings. If omitted, emails are generated with Nodemailer JSON transport.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="TURFX <no-reply@turfx.local>"

# Idempotent `npm run seed` bootstrap account.
ADMIN_NAME="TURFX Platform Owner"
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-password
ADMIN_ROTATE_PASSWORD=false
SUPPORT_EMAIL=support@example.com

# Development portfolio seed. Demo accounts match the frontend quick-login buttons.
# In production, demo data is skipped unless DEMO_SEED=true is set explicitly.
DEMO_SEED=false
DEMO_ROTATE_PASSWORD=true

# Local provider abstraction. Replace when a live gateway is implemented.
PAYMENT_PROVIDER=mock
